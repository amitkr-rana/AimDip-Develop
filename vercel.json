{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "stateVsUniTypeVsUni.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/stateVsUniTypeVsUni.json",
      "dest": "/stateVsUniTypeVsUni.json"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
